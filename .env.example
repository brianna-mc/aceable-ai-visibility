# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# Required: Anthropic API key — powers the AI Deep-Dive analysis
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google PageSpeed Insights API key
# Without this key, the free (unauthenticated) quota applies — ~25 req/day per IP.
# For team use, add a key from https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
